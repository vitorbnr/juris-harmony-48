# ══════════════════════════════════════════════════════════════════
# Viana Advocacia — Variáveis de Ambiente
# ══════════════════════════════════════════════════════════════════
# Copie para .env e preencha com valores reais:
#   cp .env.example .env
#
# O .env NÃO sobe pro Git. Apenas este .env.example sobe.
# ══════════════════════════════════════════════════════════════════

# ── Banco de Dados ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=viana
DB_USERNAME=viana
DB_PASSWORD=viana123

# ── JWT ──
JWT_SECRET=TROQUE_POR_UMA_CHAVE_SEGURA_DE_256_BITS

# ── Cloudflare R2 ──
R2_ENDPOINT=https://SEU_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY=sua_access_key
R2_SECRET_KEY=sua_secret_key
R2_BUCKET=bucket-dev

# ── Datajud (CNJ) ──
DATAJUD_API_KEY=datajud_api_key_dummy
DATAJUD_SYNC_CRON=0 0 */4 * * *
DATAJUD_SYNC_STALE_HOURS=4

# DJEN / Comunica PJe
DJEN_SYNC_ENABLED=false
DJEN_SYNC_CRON=0 30 6 * * *
DJEN_SYNC_LOOKBACK_DAYS=3
DJEN_TRIBUNAIS=
DJEN_CADERNO_TIPO=D
DJEN_API_BASE_URL=https://comunicaapi.pje.jus.br/api/v1
DJEN_USER_AGENT=JurisHarmonyPublicacoes/1.0
DJEN_TIMEOUT_SECONDS=60
DJEN_RETRY_ATTEMPTS=3
DJEN_RETRY_BACKOFF_MS=1500
DJEN_COMUNICACAO_ENABLED=true
DJEN_COMUNICACAO_PAGE_SIZE=100
DJEN_COMUNICACAO_MAX_PAGES=100
DJEN_CADERNO_FALLBACK_ENABLED=true
DJEN_CADERNO_FALLBACK_ON_EMPTY=false
DJEN_SYNC_LOCK_TTL_MINUTES=60
DJEN_BACKFILL_MAX_DAYS=31
DJEN_SYNC_SLA_HOURS=36
DJEN_SYNC_HISTORY_DAYS=14
DJEN_SLA_ALERT_ENABLED=true
DJEN_SLA_ALERT_CRON=0 15 8 * * *
DJEN_SLA_ALERT_MAX_ITENS=8
DJEN_SLA_ALERTAR_NUNCA_EXECUTADO=false

# Domicilio Judicial Eletronico (read-only)
DOMICILIO_ENABLED=false
DOMICILIO_BASE_URL=https://SEU_ENDPOINT_DOMICILIO
DOMICILIO_TOKEN_URL=https://SEU_ENDPOINT_OAUTH_TOKEN
DOMICILIO_CLIENT_ID=seu_client_id
DOMICILIO_CLIENT_SECRET=seu_client_secret
DOMICILIO_ON_BEHALF_OF=00000000000
DOMICILIO_TENANT_ID=
DOMICILIO_EU_PATH=/api/v1/eu
DOMICILIO_COMUNICACOES_PATH=/comunicacoes
DOMICILIO_LOOKBACK_DAYS=1
DOMICILIO_PAGE_SIZE=100
DOMICILIO_SYNC_CRON=0 0 */2 * * *

# Alertas internos de prazos e tarefas
PRAZO_ALERTA_CRON=0 0 8,13 * * *
PRAZO_ALERTA_LOOKAHEAD_DAYS=3
INTEGRACAO_ALERTA_CRON=0 0 * * * *
INTEGRACAO_ALERTA_THRESHOLDS=3,5,10
