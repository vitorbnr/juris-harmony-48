# Viana Advocacia — Variáveis de Ambiente
# ══════════════════════════════════════════════════════════════════
# Copie para .env e preencha com valores reais:
#   cp .env.example .env
#
# O .env NÃO sobe pro Git. Apenas este .env.example sobe.
# ══════════════════════════════════════════════════════════════════

# ── Banco de Dados ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=viana
DB_USERNAME=viana
DB_PASSWORD=viana123

# ── JWT ──
JWT_SECRET=TROQUE_POR_UMA_CHAVE_SEGURA_DE_256_BITS

# ── Cloudflare R2 ──
R2_ENDPOINT=https://SEU_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY=sua_access_key
R2_SECRET_KEY=sua_secret_key
R2_BUCKET=viana-dev
