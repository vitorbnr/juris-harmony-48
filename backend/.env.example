# ══════════════════════════════════════════════════════════════════
# Viana Advocacia — Variáveis de Ambiente
# ══════════════════════════════════════════════════════════════════
# Copie para .env e preencha com valores reais:
#   cp .env.example .env
#
# O .env NÃO sobe pro Git. Apenas este .env.example sobe.
# ══════════════════════════════════════════════════════════════════

# ── Banco de Dados ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=viana
DB_USERNAME=viana
DB_PASSWORD=viana123

# ── JWT ──
JWT_SECRET=TROQUE_POR_UMA_CHAVE_SEGURA_DE_256_BITS

# ── Cloudflare R2 ──
R2_ENDPOINT=https://SEU_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY=sua_access_key
R2_SECRET_KEY=sua_secret_key
R2_BUCKET=bucket-dev

# ── Datajud (CNJ) ──
DATAJUD_API_KEY=datajud_api_key_dummy
DATAJUD_SYNC_CRON=0 0 */4 * * *
DATAJUD_SYNC_STALE_HOURS=4

# Domicilio Judicial Eletronico (read-only)
DOMICILIO_ENABLED=false
DOMICILIO_BASE_URL=https://SEU_ENDPOINT_DOMICILIO
DOMICILIO_TOKEN_URL=https://SEU_ENDPOINT_OAUTH_TOKEN
DOMICILIO_CLIENT_ID=seu_client_id
DOMICILIO_CLIENT_SECRET=seu_client_secret
DOMICILIO_ON_BEHALF_OF=00000000000
DOMICILIO_TENANT_ID=
DOMICILIO_EU_PATH=/api/v1/eu
DOMICILIO_COMUNICACOES_PATH=/comunicacoes
DOMICILIO_SYNC_CRON=0 0 */2 * * *
